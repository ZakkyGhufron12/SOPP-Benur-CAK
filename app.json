{
  "expo": {
    "name": "SOPP-Benur CAK",
    "slug": "sopbenur2",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo_soppbenur22.png",
    "scheme": "sopbenur2",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.jakiron12.sopbenur2",
      "permissions": ["INTERNET", "CAMERA", "WRITE_EXTERNAL_STORAGE"],
      "newArchEnabled": true
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-file-system",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo_soppbenur2.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f9f5590c-9094-4540-a81a-b2ae59050949"
      }
    }
  }
}
